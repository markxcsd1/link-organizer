# Secret key to protect the API (any random string, e.g. generated with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# Groq (free tier) — get key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Notion
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DB_LOCATION=your_notion_locations_database_id
NOTION_DB_PRODUCT=your_notion_products_database_id
NOTION_DB_ARTICLE=your_notion_articles_database_id
NOTION_DB_VIDEO=your_notion_videos_database_id
NOTION_DB_RECIPE=your_notion_recipes_database_id
NOTION_DB_OTHER=your_notion_other_database_id
NOTION_DB_LOGS=your_notion_logs_database_id
NOTION_DB_GAME=your_notion_game_database_id       # optional: "To Play" DB id

# IGDB (free) — game database for genre/developer/platform (NOT trusted for release dates)
# Get credentials at dev.twitch.tv (free Twitch account required)
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Jina Reader (free) — renders JS-heavy pages (store/social) so we get the real title + store
# release date. Works with no key (20 req/min); an optional free key raises the limit (500 req/min).
# Get a key at https://jina.ai/reader
JINA_API_KEY=

# Apify (optional, free $5/mo credits) — Google Maps Scraper for accurate location ratings/reviews.
# Leave empty to keep using the DuckDuckGo fallback. Token at https://console.apify.com/account/integrations
APIFY_TOKEN=
